### OS-Specific ###
# macOS Finder metadata
.DS_Store
# macOS resource forks
._*
# macOS Spotlight index
.Spotlight-V100
# macOS Trash
.Trashes
# Windows thumbnail cache
Thumbs.db
# Windows folder config
[Dd]esktop.ini
# Windows recycle bin
$RECYCLE.BIN/
# Linux backup files
*~

### Security & Credentials ###
# Private certificates/keys
*.pem
*.key
# Certificates
*.crt
*.cer
# SSH private keys
id_rsa
id_dsa
id_ecdsa
id_ed25519
# Environment variables (may contain secrets)
.env
.env.local
# Local YAML overrides (may contain secrets or machine-specific config)
*.local.yaml

### Python ###
# Compiled bytecode
__pycache__/
# Compiled Python files
*.py[cod]
# Compiled C extensions
*.so
# Virtual environments
.venv/
venv/
env/
ENV/
# Test cache
.pytest_cache/
# Coverage reports
.coverage
htmlcov/

### Build Artifacts ###
# Plugin archive (generated by: zip -r ../mneme.plugin .)
*.plugin
*.zip

### Claude Code ###
# Local settings overrides (machine-specific, may contain personal paths or tokens)
*.local.json

### Editors ###
# VSCode settings (allow shareable config files)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
# JetBrains IDEs
.idea/
# Local edit history
.history/
# VSCode extension packages
*.vsix
# Vim swap files
*.swp
*.swo
